----- IN THE SILVER LAYER CLEANING UP THE DATA 
---STEP 1. CHECK FOR NULLS OR DUPLICATES IN PRIMARY KEY 
-- EXPECTATION : NO RESULT 


SELECT 
cst_id,
COUNT (*)
FROM bronze.crm_cust_info
GROUP BY cst_id
HAVING COUNT(*) >1 OR cst_id is NULL 


---- ONCE VERIFY THAT THERE IS DUBLICATE VALUE 
SELECT * 
FROM ( 
      SELECT *,
      ROW_NUMBER() OVER (PARTITION BY cst_id ORDER BY cst_create_date DESC) as flag_last
      FROM bronze.crm_cust_info
      WHERE cst_id IS NOT NULL
      )t WHERE flag_last =1


--step 2 : check for unwanted space 


SELECT cst_firstname
FROM bronze.crm_cust_info
WHERE cst_firstname ! = TRIM (cst_firstname)

-- IF ORIGINAL VALUE IS NOT EQUAL TO THE TRIM VALYUE , IT MEANS UNWANTED SPACE 


SELECT 
cst_id,
cst_key,
TRIM(cst_firstname) AS cst_cst_firstname,
TRIM(cst_lastname) AS cst_cst_lastname,
cst_marital_status,
cst_gndr,
cst_create_date,
FROM (
       SELECT *
       ROW_NUMBER() OVER (PARTITION BY cst_id ORDER BY cst_create_date DESC) as flag_last
      FROM bronze.crm_cust_info
      WHERE cst_id IS NOT NULL
      )t WHERE flag_last =1

--step 3 : data consistency & standardization 

SELECT DISTINCT cst_gndr
FROM bronze.crm_cust_info

--- giving full name and standadizise the whole table


SELECT 
cst_id,
cst_key,
TRIM(cst_firstname) AS cst_cst_firstname,
TRIM(cst_lastname) AS cst_cst_lastname,
case when UPPER (TRIM(cst_material_status)) = 'S'THEN 'Single'
     when UPPER (TRIM(cst_material_status)) = 'M'THEN  'Married'
     ELSE 'n/a'
     END cst_material_status ,
CASE WHEN cst_gndr = 'F' THEN 'Female'
     WHEN cst_gndr = 'M' THEN 'Male'
     ELSE 'n/a' 
     END cst_gndr,
cst_create_date
FROM (
       SELECT * ,
       ROW_NUMBER() OVER (PARTITION BY cst_id ORDER BY cst_create_date DESC) as flag_last
      FROM bronze.crm_cust_info
      WHERE cst_id IS NOT NULL
      )t WHERE flag_last =1
